# VPS production — copy to C:\helion\fleet-incident-reporter\.env and edit secrets.
NODE_ENV=production
PORT=3002

# MySQL (cases, users, incidents)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=fleet_incidents
DB_USER=fleet_app
DB_PASS=CHANGE_ME

JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CMS / tracking (local CMS on VPS)
CMSV6_BASE_URL=http://127.0.0.1:8080
CMSV6_USERNAME=Helion
CMSV6_PASSWORD=CHANGE_ME
FLEET_TIMEZONE=Africa/Dar_es_Salaam

# Shared live data (optional — defaults are ./data/...)
# DAILY_LOG_FILE=C:/helion/data/daily-log.json
# GEOCODE_CACHE_FILE=C:/helion/data/geocode-cache.json

ANALYTICS_CONCURRENCY=4
NOTIFICATION_SCAN_MS=180000
NOTIFICATION_LOOKBACK_HOURS=48

CORS_ORIGINS=https://report.heliontracking.com
